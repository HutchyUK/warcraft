# Copy this file to .env.docker and fill in the values.
# Never commit .env.docker — it contains secrets.
#
# Usage:
#   docker-compose --env-file .env.docker up --build

# PostgreSQL password (used by both the db and api services)
POSTGRES_PASSWORD=changeme

# Blizzard OAuth credentials (from developer.battle.net)
BLIZZARD_CLIENT_ID=your_blizzard_client_id
BLIZZARD_CLIENT_SECRET=your_blizzard_client_secret

# The redirect URI registered in the Blizzard developer portal.
# For docker-compose on localhost:
BLIZZARD_REDIRECT_URI=http://localhost:8080/api/auth/callback

# The URL of the frontend — used for post-login redirects and CORS.
# For docker-compose on localhost:
FRONTEND_URL=http://localhost:3000

# The backend API URL baked into the Next.js frontend at build time.
# For docker-compose on localhost (browser calls go directly to api service port):
NEXT_PUBLIC_API_URL=http://localhost:8080
